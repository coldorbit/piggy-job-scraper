DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DATABASE
DATABASE_SSL=true
WATCH_INTERVAL_MINUTES=5
JOBRIGHT_MAX_SCROLLS=30
REMOTEHUNTER_MAX_SCROLLS=10
LINKEDIN_PROXY_URLS=
# Optional: one proxy per line or comma-separated. Credentials may be embedded in each URL.
# Example: http://user:pass@proxy1.example.com:8080,http://user:pass@proxy2.example.com:8080
# Optional shared settings:
LINKEDIN_PROXY_USERNAME=
LINKEDIN_PROXY_PASSWORD=
LINKEDIN_PROXY_BYPASS=
# Optional LinkedIn AI search expansion. Requires OPENAI_API_KEY.
LINKEDIN_AI_ENRICH_SEARCHES=false
LINKEDIN_AI_SEARCH_MODEL=gpt-4.1-mini
LINKEDIN_AI_SEARCH_LIMIT=12
OPENAI_API_KEY=
# Leave destructive cleanup disabled unless you are intentionally pruning old rows.
DELETE_EXISTING_DUPLICATE_JOBS=false
DELETE_EXISTING_NON_ENGLISH_JOBS=false
